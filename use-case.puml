@startuml
title Funkenwerk Website - Use-Case-Diagramm

left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor "Besucher" as Visitor
actor "Gruender / Gruenderin" as Founder
actor "Unternehmen / Mittelstand" as Company
actor "Studierende / Absolventen" as Student
actor "Presse" as Press

rectangle "Funkenwerk Website" {

    ' Allgemeine Use Cases
    usecase "Startseite besuchen" as UC1
    usecase "Navigation nutzen" as UC2
    usecase "Kontakt aufnehmen" as UC3
    usecase "Newsletter abonnieren" as UC4
    usecase "Anschrift einsehen" as UC5

    ' Informations-Use Cases
    usecase "News und Termine lesen" as UC6
    usecase "Schwarzes Brett einsehen" as UC7
    usecase "Team kennenlernen" as UC8
    usecase "Netzwerk einsehen" as UC9
    usecase "Partnernetzwerk erkunden" as UC10
    usecase "Pressematerial herunterladen" as UC11

    ' Angebots-Use Cases
    usecase "Sprechstunde buchen" as UC12
    usecase "Seminare und Projekte entdecken" as UC13
    usecase "Inkubator-Programm erkunden" as UC14
    usecase "Forschen und Gruenden erkunden" as UC15
    usecase "Mittelstandmacher-Angebot ansehen" as UC16
    usecase "Funkenwerk-Campus erkunden" as UC17
    usecase "Abschlussarbeit-Angebot ansehen" as UC18

    ' Foerderungs-Use Cases
    usecase "Funkenwerk-Award bewerben" as UC19
    usecase "HerVenture-Programm erkunden" as UC20

    ' Team-interne Use Cases
    usecase "Gruendungsteams einsehen" as UC21
    usecase "Inkubatorteams einsehen" as UC22
    usecase "Start-Ups entdecken" as UC23
    usecase "Botschafter/innen einsehen" as UC24
    usecase "Beirat einsehen" as UC25
    usecase "Mentorinnen einsehen" as UC26
}

' Besucher (allgemein)
Visitor --> UC1
Visitor --> UC2
Visitor --> UC3
Visitor --> UC4
Visitor --> UC5
Visitor --> UC6
Visitor --> UC7
Visitor --> UC8
Visitor --> UC9
Visitor --> UC10

' Gruender / Gruenderin
Founder --> UC12
Founder --> UC13
Founder --> UC14
Founder --> UC15
Founder --> UC19
Founder --> UC20
Founder --> UC21
Founder --> UC22

' Unternehmen / Mittelstand
Company --> UC16
Company --> UC17
Company --> UC13
Company --> UC25

' Studierende / Absolventen
Student --> UC18
Student --> UC13
Student --> UC15
Student --> UC12

' Presse
Press --> UC11
Press --> UC8
Press --> UC6

' Vererbungen (extends)
UC9 ..> UC24 : <<include>>
UC9 ..> UC25 : <<include>>
UC9 ..> UC26 : <<include>>
UC9 ..> UC10 : <<include>>

UC21 ..> UC22 : <<include>>
UC21 ..> UC23 : <<include>>

UC14 ..> UC21 : <<extend>>
UC20 ..> UC22 : <<extend>>

@enduml
