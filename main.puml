@startuml
title Funkenwerk Website - Komponentenuebersicht

skinparam componentStyle rectangle
skinparam packageStyle rectangle
left to right direction

component "index.html\n(Startseite)" as Home

package "Das-Funkenwerk" {
	component "Team.html" as Team

	package "Gruendungsteams" {
		component "HerVenture-Teams.html" as HerVentureTeams
		component "Inkubatorteams.html" as Inkubatorteams
		component "Start-Ups.html" as Startups
	}

	package "Netzwerk" {
		component "Botschafter-innen.html" as Botschafter
		component "Gruendungsbeirat.html" as Beirat
		component "Mentorinnen.html" as Mentorinnen
		component "Partnernetzwerk.html" as Partnernetzwerk
	}
}

package "Aktuelles" {
	component "News-und-Termine.html" as News
	component "Schwarzes-Brett.html" as Brett
}

package "Angebote" {
	component "Sprechstunde-fuer-deine-Ideen.html" as Sprechstunde
	component "Seminare-und-Projekte.html" as Seminare
	component "Abschlussarbeit.html" as Abschlussarbeit
	component "Inkubator.html" as Inkubator
	component "Forschen-und-Gruenden.html" as Forschen
	component "Mittelstandmacher.html" as Mittelstandmacher
	component "Funkenwerk-Campus.html" as Campus

	package "Foerderungen" {
		component "HerVenture.html" as HerVentureFoerd
		component "Funkenwerk-Award.html" as Award
	}
}

package "Kontakt" {
	component "Newsletter.html" as Newsletter
	component "Pressematerial.html" as Presse
	component "Anschrift.html" as Anschrift
}

package "Gemeinsame Assets" {
	component "assets/css/styles.css" as Styles
	component "assets/js/main.js" as MainJs
	component "assets/img/*" as Images
	component "assets/banners/*" as Banners
}

package "Globale Layout-Bausteine" {
	component "Header + Navigation" as HeaderNav
	component "Footer" as Footer
}

' Startseite als Einstiegspunkt
Home --> Team
Home --> News
Home --> Sprechstunde
Home --> Seminare
